  m_text: "\u041F\u043E\u0441\u043B\u0435 \u0442\u043E\u0433\u043E, \u043A\u0430\u043A
    \u0422\u043E\u043C\u0430\u0441 \u041D\u044D\u0448\u0432\u0438\u043B\u043B \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u0432 \u043E\u0441\u043E\u0431\u043D\u044F\u043A \u0423\u044D\u0441\u0442\u0444\u0438\u043B\u0434\u043E\u0432,
    \u043E \u043D\u0451\u043C \u043D\u0438\u043A\u0442\u043E \u0431\u043E\u043B\u044C\u0448\u0435
    \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435 \u0441\u043B\u044B\u0448\u0430\u043B.
    \u041E\u0441\u043E\u0431\u043D\u044F\u043A \u043E\u0431\u044B\u0441\u043A\u0430\u043B\u0430
    \u043C\u0435\u0441\u0442\u043D\u0430\u044F \u043F\u043E\u043B\u0438\u0446\u0438\u044F,
    \u043D\u043E \u043E\u0442 \u0422\u043E\u043C\u0430\u0441\u0430 \u043D\u0435 \u043E\u0441\u0442\u0430\u043B\u043E\u0441\u044C
    \u0438 \u0441\u043B\u0435\u0434\u0430. \u0427\u0435\u0440\u0435\u0437 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043B\u0435\u0442 \u0435\u0433\u043E \u043E\u0431\u044A\u044F\u0432\u0438\u043B\u0438
    \u043F\u0440\u043E\u043F\u0430\u0432\u0448\u0438\u043C \u0431\u0435\u0437 \u0432\u0435\u0441\u0442\u0438,
    \u0430 \u043F\u0440\u043E \u0411\u0435\u043D\u0435\u0434\u0438\u043A\u0442\u0430
    \u0423\u044D\u0441\u0442\u0444\u0438\u043B\u0434\u0430 \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0438\u043B\u0430\u0441\u044C
    \u043E\u0447\u0435\u0440\u0435\u0434\u043D\u0430\u044F \u0432\u043E\u043B\u043D\u0430
    \u0441\u043B\u0443\u0445\u043E\u0432."
