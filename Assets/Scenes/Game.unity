  _progressSlider: {fileID: 1105030392}
  _ghostCharacterSprite: {fileID: 21300000, guid: 9e7771f048fdf40839b6ee9dbacad67c, type: 3}
  _ghostCharacterName: "\u0411\u0435\u043D\u0435\u0434\u0438\u043A\u0442 \u0410\u0440\u0442\u0443\u0440
    \u0423\u044D\u0441\u0442\u0444\u0438\u043B\u0434"
  _ghostCharacterDescription: "\u041F\u0440\u0438\u0437\u0440\u0430\u043A \u0431\u044B\u0432\u0448\u0435\u0433\u043E
    \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0433\u043E \u0432\u043B\u0430\u0434\u0435\u043B\u044C\u0446\u0430
    \u043E\u0441\u043E\u0431\u043D\u044F\u043A\u0430 \u0423\u044D\u0441\u0442\u0444\u0438\u043B\u0434\u043E\u0432."
  _investigatorCharacterSprite: {fileID: 21300000, guid: b7012da4ebf9008458abc3ef9a741f3c, type: 3}
  _investigatorCharacterName: "\u0422\u043E\u043C\u0430\u0441 \u041D\u044D\u0448\u0432\u0438\u043B\u043B"
  _investigatorCharacterDescription: "\u041C\u043E\u043B\u043E\u0434\u043E\u0439
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A \u0438 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C.
    \u0417\u0430\u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043B\u0441\u044F
    \u0441\u043B\u0443\u0445\u0430\u043C\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043E\u043A\u0440\u0443\u0436\u0430\u043B\u0438 \u0441\u0435\u043C\u0435\u0439\u043D\u044B\u0439
    \u043E\u0441\u043E\u0431\u043D\u044F\u043A \u0423\u044D\u0441\u0442\u0444\u0438\u043B\u0434\u043E\u0432."
  _fallbackCharacterSprite: {fileID: 21300000, guid: 69c30291565a1407abc7ca25da395ea9, type: 3}
  _fallbackCharacterName: "\u041D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436"
  _fallbackCharacterDescription: "\u0412\u044B \u0432\u0438\u0434\u0438\u0442\u0435
    \u044D\u0442\u043E\u0442 \u0442\u0435\u043A\u0441\u0442, \u0430 \u0437\u043D\u0430\u0447\u0438\u0442
    \u0432 \u043A\u043E\u0434\u0435 \u0438\u0433\u0440\u044B \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u0430
    \u043E\u0448\u0438\u0431\u043A\u0430. \u041F\u043E\u0436\u0430\u043B\u0443\u0439\u0441\u0442\u0430,
    \u0441\u043E\u043E\u0431\u0449\u0438\u0442\u0435 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A\u0430\u043C
    \u043E\u0431 \u044D\u0442\u043E\u043C."
